{
  "name": "@multiforum/auto-moderation-bot",
  "version": "0.1.0",
  "description": "AI-powered auto-moderation bot that analyzes content for rule violations and creates reports for human review",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "plugin.json",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "bundle": "node scripts/create-bundle.mjs",
    "ci": "npm run validate:manifest && npm run test && npm run build && npm run bundle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gennit-project/multiforum-plugin-auto-moderation-bot.git"
  },
  "bugs": {
    "url": "https://github.com/gennit-project/multiforum-plugin-auto-moderation-bot/issues"
  },
  "homepage": "https://github.com/gennit-project/multiforum-plugin-auto-moderation-bot#readme",
  "keywords": [
    "multiforum",
    "plugin",
    "moderation",
    "ai",
    "auto-report",
    "bot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
